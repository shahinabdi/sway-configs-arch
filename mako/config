# ~/.config/mako/config
# Dark, transparent, rounded — matches waybar accent palette.
# Real blur behind notifications comes from SwayFX (blur enable in sway/config).

sort=-time
layer=overlay
anchor=top-right
margin=10
padding=12
width=320
height=110
border-size=1
border-radius=10
icons=1
max-icon-size=32
default-timeout=5000
ignore-timeout=0

background-color=#1a1b26cc
text-color=#c0caf5
border-color=#7dcfff33
progress-color=over #7dcfff

font=JetBrainsMono Nerd Font 10

[urgency=low]
border-color=#3b4261
default-timeout=3000

[urgency=normal]
border-color=#7dcfff33

[urgency=critical]
border-color=#f7768e
text-color=#f7768e
default-timeout=0
